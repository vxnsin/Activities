{
  "$schema": "https://schemas.premid.app/metadata/1.16",
  "apiVersion": 1,
  "author": {
    "id": "413326085065801729",
    "name": "steph"
  },
  "service": "Dither",
  "description": {
    "en": "Dither is a muisc streaming platform that lets you listen & upload your own music with social features."
  },
  "url": "dither.pw",
  "regExp": "^https?[:][/][/]([a-z0-9-]+[.])*dither[.]pw[/]",
  "version": "1.0.0",
  "logo": "https://i.imgur.com/pFPLJ8y.png",
  "thumbnail": "https://i.imgur.com/eBt7dnk.png",
  "color": "#000000",
  "category": "music",
  "tags": [
    "music"
  ],
  "settings": [
    {
      "id": "browse",
      "title": "Show Browsing Activity",
      "icon": "fas fa-eye",
      "value": true
    },
    {
      "id": "song",
      "title": "Show Current Song",
      "icon": "fas fa-music",
      "value": true
    },
    {
      "id": "hidePaused",
      "title": "Hide when Paused",
      "icon": "fas fa-eye-slash",
      "value": false
    },
    {
      "id": "timestamp",
      "title": "Show Timestamps",
      "icon": "fas fa-stopwatch",
      "value": true
    },
    {
      "id": "cover",
      "title": "Show Cover Image",
      "icon": "fas fa-image",
      "value": true
    },
    {
      "id": "displayType",
      "title": "Presence Display Type",
      "icon": "fas fa-list",
      "value": 0,
      "values": [
        "Activity Name",
        "Artist Name",
        "Song Title"
      ]
    }
  ]
}
